{
  "name": "push-hygiene",
  "target": "push",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "rules": [
    {
      "type": "file_path_restriction",
      "parameters": {
        "restricted_file_paths": [
          "**/.env",
          "**/.env.local",
          "**/*.pem",
          "**/*.key",
          "**/id_rsa",
          "**/id_ed25519",
          "**/id_ecdsa",
          "**/credentials.json"
        ]
      }
    },
    {
      "type": "max_file_size",
      "parameters": {
        "max_file_size": 10
      }
    }
  ]
}
